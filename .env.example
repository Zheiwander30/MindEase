# MindEase environment variables
# Copy this file to .env and fill in your values

# Gemini 2.0 Flash API key — enables the MindEase Companion chatbot.
# Get your FREE key at https://aistudio.google.com/apikey (no credit card needed).
# Free tier: 1,500 requests/day — more than enough for student use.
# Leave blank to run chatbot in demo/mock mode.
VITE_GEMINI_API_KEY=

# face-api.js is on-device and needs no API key.
# Run `node scripts/download-models.js` once to enable live AI mood scanning.
